[Unit]
Description=Tomcat 9.0.46 servlet container
After=network.target

[Service]
Type=forking

User=tomcat
Group=tomcat

Environment="JAVA_HOME=/opt/jdk1.8.0_241"
Environment="JAVA_OPTS=-Djava.security.egd=file:///dev/urandom"

Environment="CATALINA_BASE=/opt/tomcat9.0.46"
Environment="CATALINA_HOME=/opt/tomcat9.0.46"
Environment="CATALINA_PID=/opt/tomcat9.0.46/temp/tomcat.pid"
Environment="CATALINA_OPTS=-Xms512M -Xmx1024M -server -XX:+UseParallelGC"

ExecStart="/opt/tomcat9.0.46/bin/startup.sh"
ExecStop="/opt/tomcat9.0.46/bin/shutdown.sh"

[Install]
WantedBy=multi-user.target
